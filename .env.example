# Product Coding Tool runtime config
# This package does not perform web search or scraping. It only reads an existing scrape artifact folder.

PCT_LLM_ENABLED=true
PCT_LLM_API_KEY=
PCT_LLM_API_VERSION=2024-10-21
PCT_LLM_ENDPOINT=
PCT_LLM_DEPLOYMENT=
PCT_LLM_CONSUMER_ID=
PCT_LLM_MAX_TOKENS=4096
PCT_LLM_TEMPERATURE=0.0
PCT_LLM_CONNECT_TIMEOUT=15
PCT_LLM_READ_TIMEOUT=120
PCT_LLM_MAX_RETRIES=4

PCT_LLM_VISION_ENABLED=true
PCT_LLM_VISION_MAX_IMAGES=8
PCT_LLM_VISION_DETAIL=low

PCT_CODING_MAX_ITERATIONS=2
PCT_CODING_MAX_EVIDENCE_ITEMS=12
PCT_CODING_MAX_EVIDENCE_CHARS=18000
PCT_CODING_EVIDENCE_CONTEXT_CHARS=900
PCT_CODING_READ_FILE_CHARS=6000
PCT_CODING_MIN_CONFIDENCE=0.72
PCT_CODING_OUTPUT_ROOT=data/coded

# Notebook/Jupyter stability. The installed kernel also sets IPYTHONDIR to project .ipython.
PCT_IPYTHON_DISABLE_JEDI=true

# Default LLM transport mirrors the working product_scrape_tool.
PCT_LLM_TRANSPORT=openai
PCT_LLM_PREFLIGHT_ENABLED=true
# Optional: use only for custom gateways that require a full chat/completions URL.
# PCT_LLM_TRANSPORT=httpx
# PCT_LLM_CHAT_COMPLETIONS_URL=
