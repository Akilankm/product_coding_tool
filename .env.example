# Product Coding Tool runtime config
# This package does not perform web search or scraping. It only reads an existing scrape artifact folder.

PCT_LLM_ENABLED=true
PCT_LLM_API_KEY=
PCT_LLM_API_VERSION=2024-10-21
PCT_LLM_ENDPOINT=
PCT_LLM_DEPLOYMENT=gpt-4o
PCT_LLM_CONSUMER_ID=
PCT_LLM_MAX_TOKENS=4096
PCT_LLM_TEMPERATURE=0.0
PCT_LLM_CONNECT_TIMEOUT=15
PCT_LLM_READ_TIMEOUT=120
PCT_LLM_MAX_RETRIES=4

PCT_LLM_VISION_ENABLED=true
PCT_LLM_VISION_MAX_IMAGES=8
PCT_LLM_VISION_DETAIL=low

PCT_CODING_MAX_ITERATIONS=3
PCT_CODING_MAX_EVIDENCE_ITEMS=24
PCT_CODING_MAX_EVIDENCE_CHARS=45000
PCT_CODING_EVIDENCE_CONTEXT_CHARS=1600
PCT_CODING_READ_FILE_CHARS=12000
PCT_CODING_MIN_CONFIDENCE=0.72
PCT_CODING_OUTPUT_ROOT=data/coded
